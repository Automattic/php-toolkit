{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "WordPress Blueprint v2 Schema",
	"description": "JSON Schema for WordPress Blueprint v2 format",
	"type": "object",
	"required": [
		"version"
	],
	"properties": {
		"version": {
			"type": "integer",
			"enum": [
				2
			],
			"description": "Not a generic 'number' type – this schema is specifically for Blueprints v2. Version 1 had no \"version\" field and versions 3, 4, 5, etc will be different from version 2."
		},
		"$schema": {
			"anyOf": [
				{
					"$ref": "#/definitions/URLReference"
				},
				{
					"$ref": "#/definitions/ExecutionContextPath"
				}
			],
			"description": "JSON Schema URL."
		},
		"blueprintMeta": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string",
					"description": "Example: 'WooCommerce Starter Store with Books'"
				},
				"description": {
					"type": "string",
					"description": "Example: \"A possible WooCommerce setup for selling books\""
				},
				"version": {
					"type": "string",
					"description": "Example: \"0.0.8\""
				},
				"authors": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Example: [\"Riad Benguella\", \"Adam Zieliński\"]"
				},
				"authorUrl": {
					"$ref": "#/definitions/URLReference",
					"description": "Example: \"https://example.com\""
				},
				"donateLink": {
					"$ref": "#/definitions/URLReference",
					"description": "Example: \"https://example.com\""
				},
				"tags": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Example: [\"woocommerce\", \"developer environment\"]"
				},
				"license": {
					"anyOf": [
						{
							"$ref": "#/definitions/LicenseKeyword"
						},
						{
							"type": "string"
						}
					],
					"description": "Example: \"GPLv2 or later\""
				}
			}
		},
		"siteLanguage": {
			"type": "string",
			"default": "en_US",
			"description": "Sets the WPLANG constant and downloads any missing translations for WordPress core and all the installed plugins and themes. If you need a fine-grained control over the translations, use imperative steps in the `additionalStepsAfterExecution` array."
		},
		"siteOptions": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/definitions/JsonValue"
			},
			"not": {
				"required": [
					"siteUrl"
				]
			},
			"properties": {
				"blogname": {
					"type": "string",
					"default": "My WordPress Site",
					"description": "Site title. Example: \"Adam's Movies\""
				},
				"timezone_string": {
					"type": "string",
					"default": "UTC",
					"description": "Example: \"Poland/Warsaw\""
				},
				"permalink_structure": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "boolean",
							"enum": [
								false
							]
						}
					],
					"default": "/%postname%/",
					"description": "Site permalink structure. If present and different from the current permalink structure, the Blueprint runner will run `$wp_rewrite->flush_rules();`. If you only want to set this option without flushing the rules, use an explicit `additionalStepsAfterExecution` step."
				}
			},
			"description": "Site options. In WordPress, the values are PHP-serializable, but Blueprints are intentionally restricted to a subset of those: JSON-serializable values. This is to prevent passing JavaScript Date objects."
		},
		"constants": {
			"type": "object",
			"properties": {
				"WP_DEBUG": {
					"type": "boolean"
				},
				"WP_DEBUG_LOG": {
					"type": "boolean"
				},
				"WP_DEBUG_DISPLAY": {
					"type": "boolean"
				},
				"SCRIPT_DEBUG": {
					"type": "boolean"
				}
			},
			"additionalProperties": {
				"anyOf": [
					{
						"type": "boolean"
					},
					{
						"type": "string"
					},
					{
						"type": "number"
					}
				]
			},
			"description": "Constants to define in the wp-config.php file."
		},
		"wordpressVersion": {
			"anyOf": [
				{
					"$ref": "#/definitions/WordPressVersion"
				},
				{
					"$ref": "#/definitions/URLReference"
				},
				{
					"$ref": "#/definitions/ExecutionContextPath"
				},
				{
					"type": "object",
					"required": [
						"minVersion"
					],
					"properties": {
						"minVersion": {
							"$ref": "#/definitions/WordPressVersion"
						},
						"maxVersion": {
							"$ref": "#/definitions/WordPressVersion"
						},
						"preferredVersion": {
							"$ref": "#/definitions/WordPressVersion",
							"default": "latest"
						}
					}
				}
			],
			"default": "latest",
			"description": "WordPress version to install."
		},
		"phpVersion": {
			"anyOf": [
				{
					"$ref": "#/definitions/PHPVersion"
				},
				{
					"type": "object",
					"properties": {
						"minVersion": {
							"$ref": "#/definitions/PHPVersion"
						},
						"recommendedVersion": {
							"$ref": "#/definitions/PHPVersion"
						},
						"maxVersion": {
							"$ref": "#/definitions/PHPVersion"
						}
					}
				}
			],
			"default": "8.0",
			"description": "The PHP version required for this Blueprint to work."
		},
		"activeTheme": {
			"$ref": "#/definitions/ThemeReference",
			"description": "The theme to install and also activate."
		},
		"themes": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/ThemeReference"
			},
			"description": "Installed themes to install without activating them."
		},
		"plugins": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/PluginDefinition"
			},
			"description": "A list of plugins to install and activate."
		},
		"muPlugins": {
			"anyOf": [
				{
					"$ref": "#/definitions/URLReference"
				},
				{
					"type": "array",
					"items": {
						"$ref": "#/definitions/ExecutionContextPath"
					}
				}
			],
			"description": "A list of mu-plugins to install."
		},
		"postTypes": {
			"type": "object",
			"additionalProperties": {
				"anyOf": [
					{
						"$ref": "#/definitions/PostType"
					},
					{
						"$ref": "#/definitions/ExecutionContextPath"
					}
				]
			},
			"description": "Very basic schema for defining custom post types."
		},
		"fonts": {
			"type": "object",
			"additionalProperties": {
				"anyOf": [
					{
						"$ref": "#/definitions/DataReference"
					},
					{
						"$ref": "#/definitions/FontCollection"
					}
				]
			},
			"description": "A list of fonts to register in the site's Font Library."
		},
		"media": {
			"type": "array",
			"items": {
				"anyOf": [
					{
						"$ref": "#/definitions/DataReference"
					},
					{
						"type": "object",
						"required": [
							"source"
						],
						"properties": {
							"source": {
								"$ref": "#/definitions/DataReference"
							},
							"title": {
								"type": "string"
							},
							"description": {
								"type": "string"
							},
							"alt": {
								"type": "string"
							},
							"caption": {
								"type": "string"
							}
						}
					}
				]
			},
			"description": "A list of media files to upload to the WordPress Media Library."
		},
		"content": {
			"type": "array",
			"items": {
				"anyOf": [
					{
						"type": "object",
						"required": [
							"type",
							"source"
						],
						"properties": {
							"type": {
								"type": "string",
								"enum": [
									"mysql-dump"
								]
							},
							"source": {
								"anyOf": [
									{
										"$ref": "#/definitions/DataReference"
									},
									{
										"type": "array",
										"items": {
											"$ref": "#/definitions/DataReference"
										}
									}
								]
							},
							"urlsMode": {
								"type": "string",
								"enum": [
									"rewrite",
									"preserve"
								],
								"default": "rewrite"
							},
							"urlsMap": {
								"type": "object",
								"additionalProperties": {
									"$ref": "#/definitions/URLReference"
								}
							}
						}
					},
					{
						"type": "object",
						"required": [
							"type",
							"source"
						],
						"properties": {
							"type": {
								"type": "string",
								"enum": [
									"posts"
								]
							},
							"source": {
								"anyOf": [
									{
										"$ref": "#/definitions/DataReference"
									},
									{
										"type": "array",
										"items": {
											"$ref": "#/definitions/DataReference"
										}
									},
									{
										"$ref": "#/definitions/WordPressPost"
									},
									{
										"type": "array",
										"items": {
											"$ref": "#/definitions/WordPressPost"
										}
									}
								]
							},
							"urlsMode": {
								"type": "string",
								"enum": [
									"rewrite",
									"preserve"
								],
								"default": "rewrite"
							},
							"urlsMap": {
								"type": "object",
								"additionalProperties": {
									"$ref": "#/definitions/URLReference"
								}
							}
						}
					},
					{
						"type": "object",
						"required": [
							"type",
							"source"
						],
						"properties": {
							"type": {
								"type": "string",
								"enum": [
									"wxr"
								]
							},
							"source": {
								"$ref": "#/definitions/DataReference"
							},
							"staticAssets": {
								"type": "string",
								"enum": [
									"fetch",
									"hotlink"
								],
								"default": "fetch"
							},
							"authorsMode": {
								"type": "string",
								"enum": [
									"create",
									"default-author",
									"map"
								],
								"default": "create"
							},
							"defaultAuthorUsername": {
								"type": "string",
								"default": "admin"
							},
							"authorsMap": {
								"type": "object",
								"additionalProperties": {
									"type": "string"
								}
							},
							"importUsers": {
								"type": "boolean",
								"default": false
							},
							"importComments": {
								"type": "boolean",
								"default": false
							},
							"importSiteOptions": {
								"type": "boolean",
								"default": false
							},
							"urlsMode": {
								"type": "string",
								"enum": [
									"rewrite",
									"preserve"
								],
								"default": "rewrite"
							},
							"urlsMap": {
								"type": "object",
								"additionalProperties": {
									"$ref": "#/definitions/URLReference"
								}
							}
						}
					}
				]
			},
			"description": "Content to import into the site."
		},
		"users": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"username",
					"email",
					"role"
				],
				"properties": {
					"username": {
						"type": "string"
					},
					"email": {
						"type": "string"
					},
					"role": {
						"type": "string"
					},
					"meta": {
						"type": "object",
						"additionalProperties": {
							"type": "string"
						}
					}
				}
			},
			"description": "A list of users to create."
		},
		"roles": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"name",
					"capabilities"
				],
				"properties": {
					"name": {
						"type": "string"
					},
					"capabilities": {
						"type": "object",
						"additionalProperties": {
							"type": "string"
						}
					}
				}
			},
			"description": "A list of roles to create."
		},
		"additionalStepsAfterExecution": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/Step"
			},
			"description": "Additional steps to execute after the blueprint has been executed."
		}
	},
	"definitions": {
		"URLReference": {
			"type": "string",
			"pattern": "^https?://.*",
			"description": "A reference to a HTTP or HTTPS URL."
		},
		"ExecutionContextPath": {
			"type": "string",
			"pattern": "^(/|\\./)+.*",
			"description": "A reference to a file in the Blueprint Execution Context."
		},
		"DataReference": {
			"anyOf": [
				{
					"$ref": "#/definitions/URLReference"
				},
				{
					"$ref": "#/definitions/ExecutionContextPath"
				},
				{
					"$ref": "#/definitions/InlineFile"
				},
				{
					"$ref": "#/definitions/InlineDirectory"
				},
				{
					"$ref": "#/definitions/GitPath"
				},
				{
					"type": "object",
					"required": [
						"file"
					],
					"properties": {
						"file": {
							"anyOf": [
								{
									"$ref": "#/definitions/URLReference"
								},
								{
									"$ref": "#/definitions/ExecutionContextPath"
								},
								{
									"$ref": "#/definitions/InlineFile"
								},
								{
									"$ref": "#/definitions/InlineDirectory"
								},
								{
									"$ref": "#/definitions/GitPath"
								}
							]
						},
						"humanReadableName": {
							"type": "string",
							"description": "Human-readable name of the file."
						}
					}
				}
			]
		},
		"InlineFile": {
			"type": "object",
			"required": [
				"filename",
				"content"
			],
			"properties": {
				"filename": {
					"type": "string"
				},
				"content": {
					"type": "string"
				}
			}
		},
		"InlineDirectory": {
			"type": "object",
			"required": [
				"name",
				"children"
			],
			"properties": {
				"name": {
					"type": "string"
				},
				"children": {
					"type": "array",
					"items": {
						"anyOf": [
							{
								"$ref": "#/definitions/InlineFile"
							},
							{
								"$ref": "#/definitions/InlineDirectory"
							}
						]
					}
				}
			}
		},
		"GitPath": {
			"type": "object",
			"required": [
				"gitRepository"
			],
			"properties": {
				"gitRepository": {
					"$ref": "#/definitions/URLReference"
				},
				"ref": {
					"type": "string"
				},
				"path": {
					"type": "string"
				},
				"localDirectoryName": {
					"type": "string"
				}
			}
		},
		"LicenseKeyword": {
			"type": "string",
			"enum": [
				"AFL-3.0",
				"Apache-2.0",
				"Artistic-2.0",
				"BSL-1.0",
				"BSD-2-Clause",
				"BSD-3-Clause",
				"BSD-3-Clause-Clear",
				"BSD-4-Clause",
				"0BSD",
				"CC",
				"CC0-1.0",
				"CC-BY-4.0",
				"CC-BY-SA-4.0",
				"WTFPL",
				"ECL-2.0",
				"EPL-1.0",
				"EPL-2.0",
				"EUPL-1.1",
				"AGPL-3.0",
				"GPL",
				"GPL-2.0",
				"GPL-3.0",
				"LGPL",
				"LGPL-2.1",
				"LGPL-3.0",
				"ISC",
				"LPPL-1.3c",
				"MS-PL",
				"MIT",
				"MPL-2.0",
				"OSL-3.0",
				"PostgreSQL",
				"OFL-1.1",
				"NCSA",
				"Unlicense",
				"Zlib"
			]
		},
		"JsonValue": {
			"anyOf": [
				{
					"type": "string"
				},
				{
					"type": "boolean"
				},
				{
					"type": "number"
				},
				{
					"type": "array",
					"items": {
						"$ref": "#/definitions/JsonValue"
					}
				},
				{
					"type": "object",
					"additionalProperties": {
						"$ref": "#/definitions/JsonValue"
					}
				}
			]
		},
		"WordPressVersion": {
			"anyOf": [
				{
					"type": "string",
					"enum": [
						"latest"
					]
				},
				{
					"type": "string",
					"pattern": "^\\d+\\.\\d+$"
				},
				{
					"type": "string",
					"pattern": "^\\d+\\.\\d+\\.\\d+$"
				},
				{
					"type": "string",
					"pattern": "^\\d+\\.\\d+(\\.\\d+)?-(beta\\d+|rc\\d+)$"
				}
			],
			"description": "WordPress version, e.g. \"6.4\", \"6.4.3\", \"6.8-RC1\", or \"6.7-beta2\"."
		},
		"PHPVersion": {
			"anyOf": [
				{
					"type": "string",
					"enum": [
						"latest"
					]
				},
				{
					"type": "string",
					"pattern": "^\\d+\\.\\d+$"
				},
				{
					"type": "string",
					"pattern": "^\\d+\\.\\d+\\.\\d+$"
				}
			],
			"description": "PHP version, e.g. \"8.1\" or \"8.1.3\"."
		},
		"ThemeReference": {
			"anyOf": [
				{
					"$ref": "#/definitions/ThemeDirectoryReference"
				},
				{
					"$ref": "#/definitions/URLReference"
				},
				{
					"$ref": "#/definitions/ExecutionContextPath"
				}
			]
		},
		"ThemeDirectoryReference": {
			"anyOf": [
				{
					"type": "string",
					"pattern": "^[a-zA-Z0-9_-]+$"
				},
				{
					"type": "string",
					"pattern": "^[a-zA-Z0-9_-]+@(latest|\\d+\\.\\d+(\\.\\d+)?)$"
				}
			],
			"description": "Theme directory reference, e.g. \"twentytwentythree\", \"adventurer@4.6.0\", or \"twentytwentyfour@latest\"."
		},
		"PluginDefinition": {
			"anyOf": [
				{
					"$ref": "#/definitions/PluginStringReference"
				},
				{
					"type": "object",
					"required": [
						"source"
					],
					"properties": {
						"source": {
							"$ref": "#/definitions/PluginStringReference"
						},
						"active": {
							"type": "boolean",
							"default": true
						},
						"activationOptions": {
							"type": "object",
							"additionalProperties": {
								"$ref": "#/definitions/JsonValue"
							}
						},
						"onError": {
							"type": "string",
							"enum": [
								"skip-plugin",
								"throw"
							],
							"default": "throw"
						}
					}
				}
			]
		},
		"PluginStringReference": {
			"anyOf": [
				{
					"$ref": "#/definitions/PluginDirectoryReference"
				},
				{
					"$ref": "#/definitions/URLReference"
				},
				{
					"$ref": "#/definitions/ExecutionContextPath"
				}
			]
		},
		"PluginDirectoryReference": {
			"anyOf": [
				{
					"type": "string",
					"pattern": "^[a-zA-Z0-9_-]+$"
				},
				{
					"type": "string",
					"pattern": "^[a-zA-Z0-9_-]+@(latest|\\d+\\.\\d+(\\.\\d+)?)$"
				}
			],
			"description": "Plugin directory reference, e.g. \"jetpack\", \"jetpack@6.4\", or \"akismet@6.4.3\"."
		},
		"PostType": {
			"type": "object",
			"properties": {
				"label": {
					"type": "string",
					"description": "Name of the post type shown in the menu. Usually plural."
				},
				"labels": {
					"type": "object",
					"properties": {
						"name": {
							"type": "string",
							"description": "General name for the post type, usually plural. Default is 'Posts' / 'Pages'."
						},
						"singular_name": {
							"type": "string",
							"description": "Name for one object of this post type. Default is 'Post' / 'Page'."
						},
						"add_new": {
							"type": "string",
							"description": "Label for adding a new item. Default is 'Add New' / 'Add New'."
						},
						"add_new_item": {
							"type": "string",
							"description": "Label for adding a new singular item. Default is 'Add New Post' / 'Add New Page'."
						},
						"edit_item": {
							"type": "string",
							"description": "Label for editing a singular item. Default is 'Edit Post' / 'Edit Page'."
						},
						"new_item": {
							"type": "string",
							"description": "Label for the new item page title. Default is 'New Post' / 'New Page'."
						},
						"view_item": {
							"type": "string",
							"description": "Label for viewing a singular item. Default is 'View Post' / 'View Page'."
						},
						"view_items": {
							"type": "string",
