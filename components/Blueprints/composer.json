{
	"name": "wordpress/blueprints",
	"prefer-stable": true,
	"require": {
		"ext-json": "*",
		"php": ">=7.2"
	},
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
	"config": {
		"optimize-autoloader": true,
		"preferred-install": "dist"
	},
	"autoload": {
		"classmap": [
			"src/"
		],
		"psr-4": {
			"WordPress\\": "src/WordPress",
			"Symfony\\Component\\Process\\": "src/Symfony/process",
			"Symfony\\Component\\EventDispatcher\\": "src/Symfony/event-dispatcher"
		},
        "exclude-from-classmap": [
            "/Tests/"
        ]
	},
	"autoload-dev": {
		"classmap": [
			"tests/"
		]
	},
	"scripts": {
		"test": "phpunit tests --testdox"
	},
	"require-dev": {
		"yoast/phpunit-polyfills": "^4.0",
		"phpunit/phpunit": "12"
	}
}
